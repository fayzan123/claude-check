  "homepage": "https://github.com/fayzan123/claude-check",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fayzan123/claude-check.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
